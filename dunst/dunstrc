[global]
    monitor = 0
    follow = none

    width = 320
    height = (0, 200)
    origin = top-right
    offset = (19, 20)

    notification_limit = 5
    gap_size = 8

    frame_width = 1
    frame_color = "#8B0000"

    corner_radius = 4
    corners = all

    padding = 18
    horizontal_padding = 18
    text_icon_padding = 10

    font = Monospace 10
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    ellipsize = middle
    line_height = 2

    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_corner_radius = 6
    enable_recursive_icon_lookup = true
    icon_theme = Adwaita

    separator_height = 0
    progress_bar = true
    progress_bar_height = 4
    progress_bar_corner_radius = 4

    mouse_left_click = close_current
    mouse_right_click = close_all
    mouse_middle_click = do_action, close_current

    force_xwayland = false

[urgency_low]
    background = "#0D0D0D"
    foreground = "#888888"
    frame_color = "#2a0a0a"
    timeout = 2

[urgency_normal]
    background = "#0D0D0D"
    foreground = "#E8E8E8"
    frame_color = "#8B0000"
    timeout = 4

[urgency_critical]
    background = "#1a0000"
    foreground = "#ffffff"
    frame_color = "#ff2222"
    timeout = 0
